<%- include('../partials/header', { title: 'Справочник анализов', activePage: '' }) %>
<div class="page">
  <div class="page-header">
    <h1>Справочник анализов</h1>
  </div>

  <div class="grid-2">
    <div class="card">
      <div class="card-header"><h2>Список анализов</h2></div>
      <% if (analyses.length === 0) { %>
      <div class="empty-state"><p>Справочник пуст.</p></div>
      <% } else { %>
      <table class="table">
        <thead><tr><th>#</th><th>Наименование</th><th>Цена, ₽</th><th></th></tr></thead>
        <tbody>
          <% analyses.forEach((a, i) => { %>
          <tr>
            <td class="text-muted"><%= i+1 %></td>
            <td><strong><%= a.name %></strong></td>
            <td><%= Number(a.price).toLocaleString('ru') %></td>
            <td>
              <form method="POST" action="/admin/analyses/<%= a.id %>/delete"
                    onsubmit="return confirm('Удалить «<%= a.name %>»?')">
                <button class="btn btn-sm btn-danger">Удалить</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>

    <div class="card">
      <div class="card-header"><h2>Добавить анализ</h2></div>
      <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <form method="POST" action="/admin/analyses" class="form">
        <div class="form-group">
          <label>Наименование *</label>
          <input type="text" name="name" placeholder="Например: УЗИ щитовидной железы" required>
        </div>
        <div class="form-group">
          <label>Цена, ₽</label>
          <input type="number" name="price" placeholder="0" min="0" step="0.01">
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Добавить в справочник</button>
        </div>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
