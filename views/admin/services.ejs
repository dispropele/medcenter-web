<%- include('../partials/header',{title:'Услуги',ap:''}) %>
<div class="page">
  <div class="page-header"><h1>Справочник услуг и анализов</h1></div>
  <div class="grid-2">
    <div class="card">
      <div class="card-header"><h2>Список услуг</h2><span class="badge badge-info"><%=services.length%></span></div>
      <%if(!services.length){%><div class="empty-state"><p>Пусто</p></div><%}else{%>
      <table class="table">
        <thead><tr><th>#</th><th>Наименование</th><th>Цена</th><th></th></tr></thead>
        <tbody>
          <%services.forEach(function(s,i){%>
          <tr>
            <td class="text-muted"><%=i+1%></td>
            <td>
              <strong><%=s.name%></strong>
              <%if(s.description){%><div class="text-muted" style="font-size:12px"><%=s.description%></div><%}%>
            </td>
            <td><strong><%=Number(s.price).toLocaleString('ru')%> ₽</strong></td>
            <td>
              <form method="POST" action="/admin/services/<%=s.id%>/delete" onsubmit="return confirm('Удалить «<%=s.name%>»?')">
                <button class="btn btn-sm btn-danger">Удалить</button>
              </form>
            </td>
          </tr>
          <%})%>
        </tbody>
      </table>
      <%}%>
    </div>
    <div class="card">
      <div class="card-header"><h2>Добавить услугу</h2></div>
      <%if(error){%><div class="alert alert-error" style="margin:14px 18px 0"><%=error%></div><%}%>
      <%if(success){%><div class="alert alert-success" style="margin:14px 18px 0"><%=success%></div><%}%>
      <form method="POST" action="/admin/services" class="form">
        <div class="form-group"><label>Название *</label>
          <input type="text" name="name" placeholder="Например: УЗИ щитовидной железы" required>
        </div>
        <div class="form-group"><label>Описание</label>
          <input type="text" name="description" placeholder="Краткое описание услуги">
        </div>
        <div class="form-group"><label>Цена, ₽</label>
          <input type="number" name="price" value="0" min="0" step="0.01">
        </div>
        <div class="form-actions"><button class="btn btn-primary">Добавить</button></div>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
