<%- include('../partials/header',{title:'Договоры',ap:''}) %>
<% 
  function formatDateTime(dateStr) {
    if (!dateStr) return '—';
    if (dateStr.includes('.')) return dateStr;
    const d = new Date(dateStr);
    if (isNaN(d)) return dateStr;
    const day = String(d.getDate()).padStart(2, '0');
    const month = String(d.getMonth() + 1).padStart(2, '0');
    const year = d.getFullYear();
    if (dateStr.includes('T')) {
      const hours = String(d.getHours()).padStart(2, '0');
      const minutes = String(d.getMinutes()).padStart(2, '0');
      return `${day}.${month}.${year} ${hours}:${minutes}`;
    }
    return `${day}.${month}.${year}`;
  }
%>
<div class="page">
  <div class="page-header"><h1>Договоры</h1><a href="/contracts/new" class="btn btn-primary">+ Новый договор</a></div>
  <div class="card">
    <%if(!contracts.length){%><div class="empty-state"><div class="empty-icon">📄</div><p>Договоров нет</p></div><%}else{%>
    <table class="table">
      <thead><tr><th>№</th><th>Пациент</th><th>Дата</th><th>Квитанций</th><th>Сумма</th><th></th></tr></thead>
      <tbody>
        <%contracts.forEach(function(c){%>
        <tr>
          <td class="text-muted"><%=c.id%></td>
          <td><strong><%=c.patient_name%></strong></td>
          <td><%= formatDateTime(c.date) %></td>
          <td><%=c.receipt_count%></td>
          <td><strong><%=Number(c.total).toLocaleString('ru')%> ₽</strong></td>
          <td><a href="/contracts/<%=c.id%>" class="btn btn-sm btn-outline">Открыть</a></td>
        </tr>
        <%})%>
      </tbody>
    </table>
    <%}%>
  </div>
</div>
<%- include('../partials/footer') %>
