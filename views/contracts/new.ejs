<%- include('../partials/header',{title:'Новый договор',ap:''}) %>
<% 
  function formatDateTime(dateStr) {
    if (!dateStr) return '—';
    if (dateStr.includes('.')) return dateStr;
    const d = new Date(dateStr);
    if (isNaN(d)) return dateStr;
    const day = String(d.getDate()).padStart(2, '0');
    const month = String(d.getMonth() + 1).padStart(2, '0');
    const year = d.getFullYear();
    if (dateStr.includes('T')) {
      const hours = String(d.getHours()).padStart(2, '0');
      const minutes = String(d.getMinutes()).padStart(2, '0');
      return `${day}.${month}.${year} ${hours}:${minutes}`;
    }
    return `${day}.${month}.${year}`;
  }
%>
<div class="page page-narrow">
  <div class="page-header"><h1>Новый договор</h1><a href="/contracts" class="btn btn-outline">← Назад</a></div>
  <div class="card">
    <%if(error){%><div class="alert alert-error" style="margin:16px 20px 0"><%=error%></div><%}%>
    <form method="POST" action="/contracts" class="form">
      <div class="form-row">
        <div class="form-group"><label>Посещение *</label>
          <select name="visit_id" required>
            <option value="">— Выберите посещение —</option>
            <%visits.forEach(function(v){%><option value="<%=v.id%>"><%=v.patient_name%> - <%=v.doc_name%> - <%= formatDateTime(v.datetime) %></option><%})%>
          </select>
        </div>
        <div class="form-group"><label>Дата подписания *</label>
          <input type="date" name="date" value="<%=new Date().toISOString().slice(0,10)%>" required>
        </div>
      </div>
      <div class="form-group"><label>Общая стоимость, ₽</label>
        <input type="number" name="total" value="0" min="0" step="0.01">
        <span class="form-hint">Будет пересчитана автоматически при добавлении квитанций</span>
      </div>
      <div class="form-actions">
        <a href="/contracts" class="btn btn-outline">Отмена</a>
        <button class="btn btn-primary">Создать договор</button>
      </div>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>
